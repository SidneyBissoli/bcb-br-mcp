{
  "name": "bcb-br-mcp",
  "version": "1.2.0",
  "mcpName": "io.github.SidneyBissoli/bcb-br-mcp",
  "description": "MCP Server for Brazilian Central Bank Time Series (SGS/BCB) - Economic and Financial Data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bcb-br-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:worker": "wrangler dev src/worker.ts",
    "deploy:worker": "wrangler deploy",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "bcb",
    "banco-central",
    "central-bank",
    "brazil",
    "brazilian",
    "selic",
    "ipca",
    "exchange-rate",
    "inflation",
    "financial-data",
    "economic-data",
    "gdp",
    "ai-tools",
    "claude",
    "cursor",
    "series-temporais",
    "time-series",
    "cambio"
  ],
  "author": "Sidney Bissoli <sbissoli76@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SidneyBissoli/bcb-br-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SidneyBissoli/bcb-br-mcp/issues"
  },
  "homepage": "https://github.com/SidneyBissoli/bcb-br-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "data"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.75.0"
  }
}
